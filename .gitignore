# Python
.venv/
# isolated RAGAS eval env (gitignore has NO inline comments — keep pattern on its own line)
.venv-ragas/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Data: the workbook (binary, diffs not meaningful) and all regenerable build
# artifacts (parsed/, wiki/, md/, *.json, *.graphml). Commit src/, not data/ — EXCEPT the
# hand-authored per-version curation (data/<version>/{decks,routes}.yaml), which IS committed.
data/*
!data/*/
data/*/*
!data/*/decks.yaml
!data/*/routes.yaml

# CONFIDENTIAL client material — NDA FDD reports + valuation models (Project Stella /
# Project Caesar). NEVER commit or push. Also the vision-parse cache (extracted PDF
# content = confidential) and any local backups.
test_data/
.cache/
bak/

# Frontend build / deps
frontend/node_modules/
frontend/dist/

# Editor / OS
.DS_Store
*.swp

# Secrets: never commit .env (DART_MCP_TOKEN, DART_API_KEY). Use .env.example as template.
.env

# Local agent/session state — ignore contents but DO track shared skills (committed workflows).
# Must ignore .claude/* (entries), not .claude/ (the dir), so git can descend to re-include skills.
.claude/*
!.claude/skills
docs/agent_graph.png

# detached server logs (run_server.sh / vite)
.run/
